# Ruta al  directorio en el que estan guardados los discos
export ORIGIN_DIR="/run/media/pablo/Datos I"
# Ruta donde se hace clone del repositorio
export RUN_DIR="/home/pablo/dev"
# Directorio donde se quiere almacenar el árbol que crea el programa
export EXPORT_DIR="uploads"
# Preset predefinido de HandBrake
export PRESET="Fast 480p30"